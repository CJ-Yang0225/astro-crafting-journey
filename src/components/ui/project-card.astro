---
interface Props {
  slug: string;
  title: string;
  description: string;
  technologies: string[];
  status: "completed" | "in-progress" | "archived";
  images: string[];
}

const { slug, title, description, technologies, status, images } = Astro.props;

const truncated =
  description.length > 120 ? description.slice(0, 120).trimEnd() + "…" : description;

const visibleTech = technologies.slice(0, 5);

const statusLabel: Record<Props["status"], string> = {
  completed: "Completed",
  "in-progress": "In Progress",
  archived: "Archived",
};

const statusClass: Record<Props["status"], string> = {
  completed: "bg-emerald-500/10 text-emerald-600 dark:text-emerald-400",
  "in-progress": "bg-blue-500/10 text-blue-600 dark:text-blue-400",
  archived: "bg-muted text-muted-foreground",
};

const coverImage = images[0];
---

<a
  href={`/projects/${slug}`}
  class="card_border group flex flex-col overflow-hidden rounded-lg bg-card transition-all duration-200 hover:-translate-y-0.5 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-ring"
>
  {coverImage && (
    <div class="aspect-video overflow-hidden bg-muted">
      <img
        src={coverImage}
        alt={title}
        class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
        decoding="async"
      />
    </div>
  )}

  <div class="flex flex-1 flex-col gap-3 p-5">
    <div class="flex items-start justify-between gap-2">
      <h3 class="font-heading text-lg leading-snug text-card-foreground">
        {title}
      </h3>
      <span
        class:list={[
          "shrink-0 rounded-full px-2.5 py-0.5 font-mono text-[10px] uppercase tracking-wider",
          statusClass[status],
        ]}
      >
        {statusLabel[status]}
      </span>
    </div>

    <p class="text-sm leading-relaxed text-muted-foreground">{truncated}</p>

    <div class="mt-auto flex flex-wrap gap-1.5 pt-1">
      {visibleTech.map((tech) => (
        <span class="rounded border border-border bg-muted/50 px-2 py-0.5 font-mono text-[11px] text-muted-foreground">
          {tech}
        </span>
      ))}
      {technologies.length > 5 && (
        <span class="rounded border border-border bg-muted/50 px-2 py-0.5 font-mono text-[11px] text-muted-foreground">
          +{technologies.length - 5}
        </span>
      )}
    </div>
  </div>
</a>
