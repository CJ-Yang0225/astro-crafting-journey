---
import { getCollection, render, type CollectionEntry } from "astro:content";
import OptimizedLayout from "@/layouts/optimized-layout.astro";
import MainLayout from "@/layouts/main-layout.astro";
import { generateProjectMeta } from "@/lib/seo";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((project) => ({
    params: { slug: project.id },
    props: project,
  }));
}

type Props = CollectionEntry<"projects">;

const project = Astro.props;
const { Content } = await render(project);

// 生成 SEO meta 資料
const seoMeta = generateProjectMeta(project);
---

<OptimizedLayout 
  {...seoMeta}
  structuredDataType="website"
  project={project}
>
  <MainLayout title={project.data.title} description={project.data.description}>
    <main id="main-content" class="container py-10">
      <!-- 返回按鈕 -->
      <nav class="mb-8">
        <a 
          href="/projects" 
          class="inline-flex items-center text-sm text-muted-foreground hover:text-foreground transition-colors"
        >
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
          </svg>
          返回專案列表
        </a>
      </nav>

      <article class="max-w-4xl mx-auto">
        <!-- 專案標題區 -->
        <header class="mb-8">
          <div class="flex items-center gap-3 mb-4">
            <span class={`px-3 py-1 text-sm rounded-full ${
              project.data.status === 'completed' ? 'bg-green-100 text-green-800' :
              project.data.status === 'in-progress' ? 'bg-blue-100 text-blue-800' :
              'bg-gray-100 text-gray-800'
            }`}>
              {project.data.status === 'completed' ? '已完成' :
               project.data.status === 'in-progress' ? '進行中' : '已封存'}
            </span>
            <time class="text-sm text-muted-foreground">
              {project.data.startDate.toLocaleDateString('zh-TW')}
              {project.data.endDate && ` - ${project.data.endDate.toLocaleDateString('zh-TW')}`}
            </time>
          </div>

          <h1 class="font-heading text-4xl md:text-5xl font-bold mb-4">
            {project.data.title}
          </h1>
          
          <p class="text-xl text-muted-foreground mb-6">
            {project.data.description}
          </p>

          <!-- 專案連結 -->
          <div class="flex flex-wrap gap-4 mb-8">
            {project.data.liveUrl && (
              <a 
                href={project.data.liveUrl} 
                target="_blank" 
                rel="noopener noreferrer"
                class="inline-flex items-center px-4 py-2 bg-primary text-primary-foreground rounded-md hover:bg-primary/90 transition-colors"
              >
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
                </svg>
                線上展示
              </a>
            )}
            
            {project.data.githubUrl && (
              <a 
                href={project.data.githubUrl} 
                target="_blank" 
                rel="noopener noreferrer"
                class="inline-flex items-center px-4 py-2 border border-input bg-background hover:bg-accent hover:text-accent-foreground rounded-md transition-colors"
              >
                <svg class="w-4 h-4 mr-2" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                </svg>
                查看代碼
              </a>
            )}
          </div>
        </header>

        <!-- 專案圖片 -->
        {project.data.images && project.data.images.length > 0 && (
          <section class="mb-8">
            <div class="grid gap-4">
              {project.data.images.map((image, index) => (
                <div class="aspect-video overflow-hidden rounded-lg">
                  <img 
                    src={image} 
                    alt={`${project.data.title} 截圖 ${index + 1}`}
                    class="w-full h-full object-cover"
                    loading={index === 0 ? "eager" : "lazy"}
                  />
                </div>
              ))}
            </div>
          </section>
        )}

        <!-- 技術堆疊 -->
        <section class="mb-8">
          <h2 class="text-2xl font-semibold mb-4">技術堆疊</h2>
          <div class="flex flex-wrap gap-2">
            {project.data.technologies.map((tech) => (
              <span class="px-3 py-1 bg-muted rounded-md text-sm">
                {tech}
              </span>
            ))}
          </div>
        </section>

        <!-- 專案亮點 -->
        {project.data.highlights && project.data.highlights.length > 0 && (
          <section class="mb-8">
            <h2 class="text-2xl font-semibold mb-4">專案亮點</h2>
            <ul class="space-y-2">
              {project.data.highlights.map((highlight) => (
                <li class="flex items-start">
                  <svg class="w-5 h-5 text-green-500 mr-2 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  <span>{highlight}</span>
                </li>
              ))}
            </ul>
          </section>
        )}

        <!-- 專案詳細內容 -->
        <section class="prose dark:prose-invert max-w-none">
          <Content />
        </section>
      </article>
    </main>
  </MainLayout>
</OptimizedLayout>