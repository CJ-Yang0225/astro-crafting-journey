---
import OptimizedLayout from "@/layouts/optimized-layout.astro";
import MainLayout from "@/layouts/main-layout.astro";

const seoMeta = {
  title: "聯絡我",
  description: "歡迎與我聯絡討論技術合作、專案諮詢或技術交流。提供專業的前端開發、全端解決方案和技術顧問服務。",
  type: "website" as const,
};
---

<OptimizedLayout {...seoMeta} structuredDataType="website">
  <MainLayout title="Contact" description={seoMeta.description}>
    <main id="main-content" class="container py-10">
      <!-- 頁面標題 -->
      <header class="text-center mb-12">
        <h1 class="font-heading text-4xl md:text-5xl font-bold mb-4">
          聯絡我
        </h1>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
          歡迎與我討論技術合作、專案諮詢或單純的技術交流
        </p>
      </header>

      <div class="grid lg:grid-cols-2 gap-12 max-w-6xl mx-auto">
        <!-- 聯絡表單 -->
        <section class="space-y-6">
          <div>
            <h2 class="text-2xl font-semibold mb-4">發送訊息</h2>
            <p class="text-muted-foreground mb-6">
              填寫下方表單，我會盡快回覆您的訊息
            </p>
          </div>

          <form class="space-y-6" id="contact-form">
            <!-- 姓名 -->
            <div class="space-y-2">
              <label for="name" class="text-sm font-medium">
                姓名 <span class="text-destructive">*</span>
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                class="w-full px-3 py-2 border border-input bg-background rounded-md focus:outline-none focus:ring-2 focus:ring-ring focus:border-transparent"
                placeholder="您的姓名"
              />
            </div>

            <!-- Email -->
            <div class="space-y-2">
              <label for="email" class="text-sm font-medium">
                Email <span class="text-destructive">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                class="w-full px-3 py-2 border border-input bg-background rounded-md focus:outline-none focus:ring-2 focus:ring-ring focus:border-transparent"
                placeholder="your.email@example.com"
              />
            </div>

            <!-- 主旨 -->
            <div class="space-y-2">
              <label for="subject" class="text-sm font-medium">
                主旨 <span class="text-destructive">*</span>
              </label>
              <select
                id="subject"
                name="subject"
                required
                class="w-full px-3 py-2 border border-input bg-background rounded-md focus:outline-none focus:ring-2 focus:ring-ring focus:border-transparent"
              >
                <option value="">請選擇主旨</option>
                <option value="project-collaboration">專案合作</option>
                <option value="technical-consultation">技術諮詢</option>
                <option value="job-opportunity">工作機會</option>
                <option value="technical-discussion">技術交流</option>
                <option value="other">其他</option>
              </select>
            </div>

            <!-- 訊息內容 -->
            <div class="space-y-2">
              <label for="message" class="text-sm font-medium">
                訊息內容 <span class="text-destructive">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows="6"
                class="w-full px-3 py-2 border border-input bg-background rounded-md focus:outline-none focus:ring-2 focus:ring-ring focus:border-transparent resize-vertical"
                placeholder="請詳細描述您的需求或想討論的內容..."
              ></textarea>
            </div>

            <!-- 提交按鈕 -->
            <button
              type="submit"
              class="w-full bg-primary text-primary-foreground px-6 py-3 rounded-md font-medium hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 transition-colors"
            >
              發送訊息
            </button>

            <!-- 表單狀態訊息 -->
            <div id="form-status" class="hidden p-4 rounded-md"></div>
          </form>
        </section>

        <!-- 聯絡資訊與社群連結 -->
        <section class="space-y-8">
          <!-- 聯絡方式 -->
          <div>
            <h2 class="text-2xl font-semibold mb-6">其他聯絡方式</h2>
            <div class="space-y-4">
              <div class="flex items-center space-x-3">
                <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center">
                  <svg class="w-5 h-5 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                  </svg>
                </div>
                <div>
                  <p class="font-medium">Email</p>
                  <p class="text-muted-foreground">hello@example.com</p>
                </div>
              </div>

              <div class="flex items-center space-x-3">
                <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center">
                  <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                  </svg>
                </div>
                <div>
                  <p class="font-medium">GitHub</p>
                  <p class="text-muted-foreground">@your-username</p>
                </div>
              </div>

              <div class="flex items-center space-x-3">
                <div class="w-10 h-10 bg-primary/10 rounded-full flex items-center justify-center">
                  <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                </div>
                <div>
                  <p class="font-medium">LinkedIn</p>
                  <p class="text-muted-foreground">@your-profile</p>
                </div>
              </div>
            </div>
          </div>

          <!-- 合作類型 -->
          <div>
            <h3 class="text-xl font-semibold mb-4">合作類型</h3>
            <div class="grid gap-4">
              <div class="p-4 border rounded-lg">
                <h4 class="font-medium mb-2">前端開發</h4>
                <p class="text-sm text-muted-foreground">
                  React, Vue, Astro 等現代前端框架開發
                </p>
              </div>
              
              <div class="p-4 border rounded-lg">
                <h4 class="font-medium mb-2">全端解決方案</h4>
                <p class="text-sm text-muted-foreground">
                  從前端到後端的完整技術解決方案
                </p>
              </div>
              
              <div class="p-4 border rounded-lg">
                <h4 class="font-medium mb-2">技術顧問</h4>
                <p class="text-sm text-muted-foreground">
                  架構設計、技術選型和開發流程優化
                </p>
              </div>
              
              <div class="p-4 border rounded-lg">
                <h4 class="font-medium mb-2">開源貢獻</h4>
                <p class="text-sm text-muted-foreground">
                  參與開源專案開發和技術社群交流
                </p>
              </div>
            </div>
          </div>

          <!-- 回覆時間說明 -->
          <div class="p-4 bg-muted/50 rounded-lg">
            <h4 class="font-medium mb-2">回覆時間</h4>
            <p class="text-sm text-muted-foreground">
              我通常會在 24-48 小時內回覆您的訊息。如果是緊急事項，請在訊息中註明。
            </p>
          </div>
        </section>
      </div>
    </main>
  </MainLayout>
</OptimizedLayout>

<script>
  // 聊絡表單處理
  document.addEventListener('DOMContentLoaded', function() {
    const form = document.getElementById('contact-form') as HTMLFormElement;
    const statusDiv = document.getElementById('form-status') as HTMLDivElement;

    if (form) {
      form.addEventListener('submit', async function(e) {
        e.preventDefault();
        
        // 顯示載入狀態
        const submitButton = form.querySelector('button[type="submit"]') as HTMLButtonElement;
        const originalText = submitButton.textContent;
        submitButton.textContent = '發送中...';
        submitButton.disabled = true;

        try {
          const formData = new FormData(form);
          
          // TODO: 實作 Golang 後端 API 呼叫
          // const response = await fetch('/api/contact', {
          //   method: 'POST',
          //   body: formData
          // });

          // 模擬 API 呼叫
          await new Promise(resolve => setTimeout(resolve, 1000));
          
          // 成功狀態
          statusDiv.className = 'p-4 rounded-md bg-green-50 border border-green-200 text-green-800';
          statusDiv.textContent = '訊息已成功發送！我會盡快回覆您。';
          statusDiv.classList.remove('hidden');
          
          // 重置表單
          form.reset();
          
        } catch (error) {
          // 錯誤狀態
          statusDiv.className = 'p-4 rounded-md bg-red-50 border border-red-200 text-red-800';
          statusDiv.textContent = '發送失敗，請稍後再試或直接發送 Email 給我。';
          statusDiv.classList.remove('hidden');
        } finally {
          // 恢復按鈕狀態
          submitButton.textContent = originalText;
          submitButton.disabled = false;
        }
      });
    }
  });
</script>