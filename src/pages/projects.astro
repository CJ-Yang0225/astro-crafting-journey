---
import { getCollection } from "astro:content";
import OptimizedLayout from "@/layouts/optimized-layout.astro";
import MainLayout from "@/layouts/main-layout.astro";

// 獲取專案資料
const projects = await getCollection("projects");
const featuredProjects = projects.filter(project => project.data.featured);
const allProjects = projects.sort((a, b) => 
  b.data.startDate.getTime() - a.data.startDate.getTime()
);

const seoMeta = {
  title: "專案作品集",
  description: "展示我的技術專案、開源貢獻和實驗性作品。包含前端應用、全端解決方案、技術實驗等各類開發項目。",
  type: "website" as const,
};
---

<OptimizedLayout {...seoMeta} structuredDataType="website">
  <MainLayout title="Projects" description={seoMeta.description}>
    <main id="main-content" class="container py-10">
      {/* 頁面標題 */}
      <header class="text-center mb-12">
        <h1 class="font-heading text-4xl md:text-5xl font-bold mb-4">
          專案作品集
        </h1>
        <p class="text-lg text-muted-foreground max-w-2xl mx-auto">
          展示我的技術專案、開源貢獻和實驗性作品
        </p>
      </header>

      {/* 專案分類篩選 */}
      <div class="flex flex-wrap justify-center gap-2 mb-12">
        <button class="filter-btn active px-4 py-2 rounded-full border transition-colors" data-filter="all">
          全部
        </button>
        <button class="filter-btn px-4 py-2 rounded-full border transition-colors" data-filter="showcase">
          精選作品
        </button>
        <button class="filter-btn px-4 py-2 rounded-full border transition-colors" data-filter="experimental">
          技術實驗
        </button>
        <button class="filter-btn px-4 py-2 rounded-full border transition-colors" data-filter="learning">
          學習專案
        </button>
      </div>

      {/* 精選專案 */}
      {featuredProjects.length > 0 && (
        <section class="mb-16">
          <h2 class="text-2xl font-semibold mb-8 text-center">精選專案</h2>
          <div class="grid md:grid-cols-2 gap-8">
            {featuredProjects.map((project) => (
              <article class="project-card group border rounded-lg overflow-hidden hover:shadow-lg transition-shadow" data-category="showcase">
                {/* 專案圖片 */}
                {project.data.images && project.data.images.length > 0 && (
                  <div class="aspect-video overflow-hidden">
                    <img 
                      src={project.data.images[0]} 
                      alt={project.data.title}
                      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
                      loading="lazy"
                    />
                  </div>
                )}
                
                <div class="p-6">
                  {/* 專案狀態 */}
                  <div class="flex items-center justify-between mb-3">
                    <span class={`px-2 py-1 text-xs rounded-full ${
                      project.data.status === 'completed' ? 'bg-green-100 text-green-800' :
                      project.data.status === 'in-progress' ? 'bg-blue-100 text-blue-800' :
                      'bg-gray-100 text-gray-800'
                    }`}>
                      {project.data.status === 'completed' ? '已完成' :
                       project.data.status === 'in-progress' ? '進行中' : '已封存'}
                    </span>
                    <time class="text-sm text-muted-foreground">
                      {project.data.startDate.getFullYear()}
                    </time>
                  </div>

                  {/* 專案標題與描述 */}
                  <h3 class="text-xl font-semibold mb-2 group-hover:text-primary transition-colors">
                    <a href={`/projects/${project.id}`} class="stretched-link">
                      {project.data.title}
                    </a>
                  </h3>
                  <p class="text-muted-foreground mb-4 line-clamp-2">
                    {project.data.description}
                  </p>

                  {/* 技術標籤 */}
                  <div class="flex flex-wrap gap-2 mb-4">
                    {project.data.technologies.slice(0, 4).map((tech) => (
                      <span class="px-2 py-1 text-xs bg-muted rounded">
                        {tech}
                      </span>
                    ))}
                    {project.data.technologies.length > 4 && (
                      <span class="px-2 py-1 text-xs bg-muted rounded">
                        +{project.data.technologies.length - 4}
                      </span>
                    )}
                  </div>

                  {/* 專案連結 */}
                  <div class="flex gap-3">
                    {project.data.liveUrl && (
                      <a 
                        href={project.data.liveUrl} 
                        target="_blank" 
                        rel="noopener noreferrer"
                        class="text-sm text-primary hover:underline"
                      >
                        線上展示
                      </a>
                    )}
                    {project.data.githubUrl && (
                      <a 
                        href={project.data.githubUrl} 
                        target="_blank" 
                        rel="noopener noreferrer"
                        class="text-sm text-primary hover:underline"
                      >
                        GitHub
                      </a>
                    )}
                  </div>
                </div>
              </article>
            ))}
          </div>
        </section>
      )}

      {/* 所有專案 */}
      <section>
        <h2 class="text-2xl font-semibold mb-8 text-center">所有專案</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6" id="projects-grid">
          {allProjects.map((project) => (
            <article class="project-card border rounded-lg overflow-hidden hover:shadow-md transition-shadow" data-category="all">
              {/* 專案縮圖 */}
              {project.data.images && project.data.images.length > 0 && (
                <div class="aspect-video overflow-hidden">
                  <img 
                    src={project.data.images[0]} 
                    alt={project.data.title}
                    class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
                    loading="lazy"
                  />
                </div>
              )}
              
              <div class="p-4">
                {/* 專案狀態與日期 */}
                <div class="flex items-center justify-between mb-2">
                  <span class={`px-2 py-1 text-xs rounded-full ${
                    project.data.status === 'completed' ? 'bg-green-100 text-green-800' :
                    project.data.status === 'in-progress' ? 'bg-blue-100 text-blue-800' :
                    'bg-gray-100 text-gray-800'
                  }`}>
                    {project.data.status === 'completed' ? '已完成' :
                     project.data.status === 'in-progress' ? '進行中' : '已封存'}
                  </span>
                  <time class="text-xs text-muted-foreground">
                    {project.data.startDate.getFullYear()}
                  </time>
                </div>

                {/* 專案標題 */}
                <h3 class="font-semibold mb-2 hover:text-primary transition-colors">
                  <a href={`/projects/${project.id}`} class="stretched-link">
                    {project.data.title}
                  </a>
                </h3>

                {/* 專案描述 */}
                <p class="text-sm text-muted-foreground mb-3 line-clamp-2">
                  {project.data.description}
                </p>

                {/* 主要技術 */}
                <div class="flex flex-wrap gap-1 mb-3">
                  {project.data.technologies.slice(0, 3).map((tech) => (
                    <span class="px-2 py-1 text-xs bg-muted rounded">
                      {tech}
                    </span>
                  ))}
                  {project.data.technologies.length > 3 && (
                    <span class="px-2 py-1 text-xs bg-muted rounded">
                      +{project.data.technologies.length - 3}
                    </span>
                  )}
                </div>

                {/* 快速連結 */}
                <div class="flex gap-2 text-xs">
                  {project.data.liveUrl && (
                    <a 
                      href={project.data.liveUrl} 
                      target="_blank" 
                      rel="noopener noreferrer"
                      class="text-primary hover:underline"
                    >
                      展示
                    </a>
                  )}
                  {project.data.githubUrl && (
                    <a 
                      href={project.data.githubUrl} 
                      target="_blank" 
                      rel="noopener noreferrer"
                      class="text-primary hover:underline"
                    >
                      代碼
                    </a>
                  )}
                </div>
              </div>
            </article>
          ))}
        </div>

        {/* 空狀態 */}
        {allProjects.length === 0 && (
          <div class="text-center py-12">
            <p class="text-muted-foreground mb-4">目前還沒有專案展示</p>
            <p class="text-sm text-muted-foreground">
              正在努力開發中，敬請期待！
            </p>
          </div>
        )}
      </section>
    </main>
  </MainLayout>
</OptimizedLayout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  .stretched-link::after {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    z-index: 1;
    content: "";
  }
  
  .project-card {
    position: relative;
  }
  
  .filter-btn.active {
    background-color: hsl(var(--primary));
    color: hsl(var(--primary-foreground));
    border-color: hsl(var(--primary));
  }
  
  .filter-btn:hover {
    background-color: hsl(var(--muted));
  }
</style>

<script>
  // 專案篩選功能
  document.addEventListener('DOMContentLoaded', function() {
    const filterButtons = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
    const projectCards = document.querySelectorAll<HTMLElement>('.project-card');

    filterButtons.forEach(button => {
      button.addEventListener('click', function(this: HTMLButtonElement) {
        const filter = this.getAttribute('data-filter');
        
        // 更新按鈕狀態
        filterButtons.forEach(btn => btn.classList.remove('active'));
        this.classList.add('active');
        
        // 篩選專案
        projectCards.forEach(card => {
          const category = card.getAttribute('data-category');
          if (filter === 'all' || category === filter || category === 'all') {
            (card as HTMLElement).style.display = 'block';
          } else {
            (card as HTMLElement).style.display = 'none';
          }
        });
      });
    });
  });
</script>